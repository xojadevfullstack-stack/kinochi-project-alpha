# Kinochi Backend — environment variables EXAMPLE
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — only .env.example!

# ── General ──────────────────────────────────────────────────────
PROJECT_NAME=Kinochi
VERSION=0.1.0
APP_ENV=development
DEBUG=false

# ── Database (async PostgreSQL) ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kinochi:your_db_password@localhost:5432/kinochi
POSTGRES_USER=kinochi
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=kinochi

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS (JSON array of allowed origins) ─────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Security ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_64_char_hex_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Telegram ─────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
STORAGE_CHANNEL_ID=your_storage_channel_id_here
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
BOT_API_SECRET=your_bot_api_secret_here
